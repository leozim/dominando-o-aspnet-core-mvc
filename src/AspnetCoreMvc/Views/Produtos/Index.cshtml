@model IEnumerable<AspnetCoreMvc.Models.Produto>

@{
    ViewData["Title"] = "Lista de Produtos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>@ViewData["Title"]</h1>

<p>
    <a class="btn btn-primary" asp-action="Create"><span class="fa fa-plus"></span> Novo</a>
</p>
<table class="table">
    <thead>
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.Nome)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Imagem)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Valor)
        </th>
        <th></th>
    </tr>
    </thead>
    <tbody>
    @foreach (var item in Model) {
        <tr>
            <td>
                <img src="/images/@item.Imagem" style="height: 100px; width: 61px" />
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Nome)
            </td>
            <td>
                R$ @Html.DisplayFor(modelItem => item.Valor)
            </td>
            <td>
                <botao tipo-botao="Detalhes" route-id="@item.Id"></botao>
                <botao tipo-botao="Editar"   route-id="@item.Id"></botao>
                <botao tipo-botao="Excluir"  route-id="@item.Id"></botao>
                @*
                <a asp-action="Details" class="btn btn-warning" asp-route-id="@item.Id"><span class="fa fa-search"></span></a>
                <a asp-action="Edit" class="btn btn-info" asp-route-id="@item.Id"><span class="fa fa-pencil-alt"></span></a>
                <a asp-action="Delete" class="btn btn-danger" asp-route-id="@item.Id"><span class="fa fa-trash"></span></a>
                *@
            </td>
        </tr>
    }
    </tbody>
</table>

<vc:counter model-counter="@Model.Count()"></vc:counter>
@*@await Component.InvokeAsync("Counter", Model.Count())*@
